<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <RootNamespace>M_uninstaller</RootNamespace>
    <Nullable>enable</Nullable>
    <UseWindowsForms>true</UseWindowsForms>
	  
    <ImplicitUsings>enable</ImplicitUsings>
    <ApplicationManifest>app.manifest</ApplicationManifest>

	  <!-- App Ico -->

	  <!-- App Info -->
	  <AssemblyTitle>MunInstaller</AssemblyTitle>
	  <AssemblyVersion>1.0.0.0</AssemblyVersion>
	  <FileVersion>1.0.0.0</FileVersion>
	  <Company>$(Mk Dev Company)</Company>
	  <Product>MunInstaller</Product>
	  <Description>Professional Windows Uninstaller</Description>
	  <Copyright>© 2026 Mk Dev Company</Copyright>
	  <Authors>$(Mahendra)</Authors>
    
    <IncludeSymbols>False</IncludeSymbols>
    
    <ApplicationIcon>app.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <Content Include="app.ico" />
  </ItemGroup>

</Project>